# Copy this file to .env.local for local development (vercel dev) and
# fill in real values there. Never commit .env or .env.local to git.
# In production, set these in your hosting provider's dashboard instead
# (Vercel: Project Settings → Environment Variables).

# Required. Your real Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. If set, the app will require this password (entered in the
# app's ⚙ settings screen) before it will call Gemini. Leave blank to
# allow anyone with the URL to use it.
APP_SECRET=
